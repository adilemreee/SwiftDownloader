{
  "manifest_version": 2,
  "name": "SwiftDownloader",
  "description": "Intercepts downloads and sends them to SwiftDownloader app",
  "version": "1.0",
  "permissions": [
    "nativeMessaging",
    "activeTab"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "SwiftDownloader"
  }
}
